# ── Database ──────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string (required)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Email (Resend) ────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys (required)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Verified sender address configured in Resend (required)
RESEND_FROM=noreply@yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL of the Next.js frontend, used in email links (required)
FRONTEND_BASE_URL=http://localhost:3000

# ── Billing (Paddle) ──────────────────────────────────────────────────────────
# Secret API key from https://vendors.paddle.com/api-key (required)
PADDLE_API_KEY=your_paddle_api_key
# Webhook signing secret from the Paddle dashboard (required)
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
# Paddle API base URL — defaults to sandbox; change to https://api.paddle.com in production (optional)
PADDLE_API_BASE=https://sandbox-api.paddle.com
# Paddle price ID used for overage billing (optional)
PADDLE_OVERAGE_PRICE_ID=pri_xxxxxxxxxxxx

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email address of the admin user (required)
ADMIN_EMAIL=admin@yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────────
# Port the backend listens on — defaults to 3001 (optional)
PORT=3001
# Pricing config file path — defaults to bin/kaya-cloud/config/pricing.yaml (optional)
PRICING_CONFIG_PATH=config/pricing.yaml
# Log filter passed to tracing-subscriber — defaults to "info" (optional)
RUST_LOG=info
