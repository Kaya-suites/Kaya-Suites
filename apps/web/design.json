{
  "colors": {
    "background":       "#E8F4F8",
    "surface":          "#FFFFFF",
    "foreground":       "#000000",
    "border":           "#000000",
    "accent":           "#0047FF",
    "accentForeground": "#FFFFFF",
    "muted":            "#3A3A3A",
    "mutedBackground":  "#C8DCE8",
    "danger":           "#FF3D00",
    "dangerForeground": "#FFFFFF",
    "success":          "#00875A",
    "successForeground":"#FFFFFF",
    "warning":          "#FFB800",
    "warningForeground":"#000000"
  },
  "typography": {
    "fontFamily":    "'Geist Mono', 'Courier New', monospace",
    "fontFamilyMono":"'Geist Mono', 'Courier New', monospace",
    "fontSizes": {
      "xs":   "0.75rem",
      "sm":   "0.8125rem",
      "base": "0.9375rem",
      "lg":   "1.125rem",
      "xl":   "1.25rem",
      "2xl":  "1.5rem",
      "3xl":  "1.875rem",
      "4xl":  "2.25rem"
    },
    "fontWeights": {
      "normal": "400",
      "medium": "500",
      "bold":   "700",
      "black":  "900"
    },
    "letterSpacing": {
      "normal": "0em",
      "wide":   "0.04em",
      "wider":  "0.08em"
    }
  },
  "spacing": {
    "borderWidth":      "2px",
    "borderWidthThick": "3px",
    "shadowOffsetX":    "4px",
    "shadowOffsetY":    "4px",
    "shadowColor":      "#000000",
    "borderRadius":     "4px"
  },
  "components": {
    "button": {
      "paddingX":      "1rem",
      "paddingY":      "0.5rem",
      "shadow":        "4px 4px 0px #000000",
      "shadowHover":   "6px 6px 0px #000000",
      "fontWeight":    "700",
      "letterSpacing": "0.06em",
      "textTransform": "uppercase"
    },
    "card": {
      "padding": "1.25rem",
      "shadow":  "4px 4px 0px #000000"
    },
    "nav": {
      "width":      "11rem",
      "background": "#E8F4F8"
    },
    "input": {
      "paddingX": "0.75rem",
      "paddingY": "0.5rem",
      "shadow":   "2px 2px 0px #000000"
    },
    "chatBubble": {
      "userBackground":      "#0047FF",
      "userForeground":      "#FFFFFF",
      "assistantBackground": "#FFFFFF",
      "assistantForeground": "#000000",
      "shadow":              "3px 3px 0px #000000"
    }
  },
  "mdxEditor": {
    "table": {
      "dataToolCellTrue":{
        "border": "none",
        "background": "#E8F4F8"
      },
      "dataToolCellFalse": {
        "border": "#000000"
      }
    }
  }
}
