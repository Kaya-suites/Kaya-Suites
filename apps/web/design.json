{
  "$schema": "Token source for the warm/editorial design system. Compiled by scripts/build-theme.mjs into app/theme.generated.css.",

  "modes": {
    "light": {
      "bg":              "#F5F5F5",
      "bgSubtle":        "#ECECEC",
      "bgElevated":      "#FFFFFF",
      "surface":         "#FFFFFF",
      "surfaceElevated": "#FFFFFF",

      "text":            "#1A1A1A",
      "textMuted":       "#4A4A4A",
      "textSubtle":      "#7A7A7A",
      "textInverse":     "#F5F5F5",

      "border":          "#DFDFDF",
      "borderStrong":    "#1A1A1A",
      "borderSubtle":    "#EBEBEB",

      "accent":          "#1A1A1A",
      "accentFg":        "#F5F5F5",
      "accentMuted":     "#E0E0E0",
      "accentHover":     "#000000",

      "success":         "#4F6F58",
      "successFg":       "#FFFFFF",
      "warning":         "#756138",
      "warningFg":       "#FFFFFF",
      "danger":          "#7A3D3D",
      "dangerFg":        "#FFFFFF",

      "focus":           "#1A1A1A",
      "shadow":          "rgba(0, 0, 0, 0.08)"
    },
    "dark": {
      "bg":              "#121212",
      "bgSubtle":        "#1C1C1C",
      "bgElevated":      "#242424",
      "surface":         "#1C1C1C",
      "surfaceElevated": "#242424",

      "text":            "#F0F0F0",
      "textMuted":       "#B0B0B0",
      "textSubtle":      "#707070",
      "textInverse":     "#1A1A1A",

      "border":          "#2E2E2E",
      "borderStrong":    "#F0F0F0",
      "borderSubtle":    "#242424",

      "accent":          "#F0F0F0",
      "accentFg":        "#1A1A1A",
      "accentMuted":     "#2E2E2E",
      "accentHover":     "#FFFFFF",

      "success":         "#8FAA98",
      "successFg":       "#121212",
      "warning":         "#C9A969",
      "warningFg":       "#121212",
      "danger":          "#C68A8A",
      "dangerFg":        "#121212",

      "focus":           "#F0F0F0",
      "shadow":          "rgba(0, 0, 0, 0.5)"
    }
  },

  "typography": {
    "fontSerif": "var(--font-fraunces), 'Iowan Old Style', Georgia, 'Times New Roman', serif",
    "fontSans":  "var(--font-inter), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "fontMono":  "var(--font-jetbrains-mono), 'Geist Mono', 'JetBrains Mono', 'Courier New', monospace",
    "fontSizes": {
      "xs":   "0.75rem",
      "sm":   "0.875rem",
      "base": "1rem",
      "lg":   "1.125rem",
      "xl":   "1.25rem",
      "2xl":  "1.5rem",
      "3xl":  "1.875rem",
      "4xl":  "2.25rem",
      "5xl":  "3rem",
      "6xl":  "3.75rem",
      "7xl":  "4.5rem"
    },
    "lineHeights": {
      "tight":   "1.15",
      "snug":    "1.3",
      "normal":  "1.5",
      "relaxed": "1.65",
      "loose":   "1.8"
    },
    "fontWeights": {
      "normal":   "400",
      "medium":   "500",
      "semibold": "600",
      "bold":     "700"
    },
    "letterSpacing": {
      "tight":  "-0.02em",
      "normal": "0em",
      "wide":   "0.04em",
      "wider":  "0.08em"
    }
  },

  "spacing": {
    "borderWidth":      "1px",
    "borderWidthThick": "2px",
    "radiusSm":         "4px",
    "radiusMd":         "6px",
    "radiusLg":         "10px",
    "radiusXl":         "16px",
    "radiusPill":       "9999px",
    "shadowSm":         "0 1px 2px var(--color-shadow)",
    "shadowMd":         "0 2px 8px var(--color-shadow)",
    "shadowLg":         "0 8px 24px var(--color-shadow)"
  },

  "components": {
    "nav": {
      "width": "13rem"
    },
    "button": {
      "paddingX":      "0.875rem",
      "paddingY":      "0.5rem",
      "fontWeight":    "500",
      "letterSpacing": "0em"
    },
    "input": {
      "paddingX": "0.75rem",
      "paddingY": "0.5rem"
    },
    "card": {
      "padding": "1.25rem"
    },
    "chatBubble": {
      "userBg":         "var(--color-accent)",
      "userFg":         "var(--color-accent-fg)",
      "assistantBg":    "var(--color-surface)",
      "assistantFg":    "var(--color-text)"
    }
  }
}
